   my $GIT = "/usr/bin/git";
   my $user = 'git';
   my ($rc,$cmd) = (0,'');

   my $dir_local = '/opt/'.$feature;

   if ((-d $dir_local) && (-d "$dir_local/.git")) {

      chdir($dir_local);
      print "pull from $url ...\n";
      $cmd = "$GIT pull";
      $rc = system ($cmd);
      if ($rc !=0) { 
			print "**WARNNG** Found local changes - pull exits (rc=$rc)\n"; 
			exit;
		}
      $cmd = "$GIT checkout";
      $rc = system ($cmd);
      if ($rc !=0) { print "**WARN** $cmd (rc=$rc)\n"; }

   }
   else {

      print "clone from $url ...\n";
