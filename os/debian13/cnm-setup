#-------------------------------------------------------------------------------------------
# Lee la clave de la seccion [client] de un fichero estilo my.cnf
#-------------------------------------------------------------------------------------------
sub read_my_cnf {
my ($file) = @_;
   return undef unless -f $file;
   open (my $fh,'<',$file) or return undef;
   my $in_client = 0;
   my $pwd;
   while (my $line = <$fh>) {
      chomp $line;
      $line =~ s/^\s+//; $line =~ s/\s+$//;
      next if $line eq '' || $line =~ /^[#;]/;          # comentarios / vacias
      if ($line =~ /^\[(.+)\]$/) {                       # cabecera de seccion
         $in_client = (lc($1) eq 'client') ? 1 : 0;
         next;
      }
      next unless $in_client;
      if ($line =~ /^password\s*=\s*(.*)$/i) {
         $pwd = $1;
         $pwd =~ s/^["']//; $pwd =~ s/["']$//;           # quita comillas opcionales
         last;
      }
   }
   close $fh;
   return $pwd;
}
 
#-------------------------------------------------------------------------------------------
#-------------------------------------------------------------------------------------------
sub create_script {
my ($script_file)=@_;

   local($/) = undef;  # slurp
	my $script_code = <DATA>;
	open (F,">$script_file");
	print F "$script_code\n";
	close F;
	chmod 0755, $script_file;
}

