         $cmd = "/bin/rm -rf $dir_local";
         $rc = system ($cmd);
         if ($rc !=0) { print "$cmd (rc=$rc)\n"; }
      }
      #$cmd = "$GIT clone -b $BRANCH https://$user:\@$REPO/$feature.git $dir_local";
      $cmd = "$GIT clone -b $BRANCH $url $dir_local";
